{
  "id": "/?source=pwa",
  "name": "Sidão Dicas",
  "short_name": "Sidão Dicas",
  "description": "Portal de ofertas e produtos selecionados.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "tabbed",
    "window-controls-overlay",
    "standalone",
    "minimal-ui"
  ],
  "background_color": "#0f172a",
  "theme_color": "#FFEA00",
  "orientation": "portrait",
